# Backend environment — copy to backend/.env (and optionally backend/.env.local for overrides)
# Prisma CLI commands also read backend/.env automatically.

# Database
DATABASE_URL="postgresql://liqvia:liqvia@localhost:5432/liqvia2?schema=public"

# Set to true to skip automatic `prisma migrate deploy` on startup
SKIP_DB_MIGRATE=

# Server
PORT=3000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# JWT authentication
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRES_IN=7d

# Password reset (public app URL for email links)
APP_URL=http://localhost:3000

# Optional SMTP — when unset, reset links are logged to the server console
# and shown on the forgot-password page in development.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@liqvia.com

# OpenAI (AI CFO). When empty, the API uses a rule-based briefing fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
