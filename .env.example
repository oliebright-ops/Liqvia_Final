# Liqvia runs as a single Next.js app (UI + /api on one port).
#
#   backend/.env.example  →  copy to backend/.env  (DATABASE_URL, JWT_SECRET, OpenAI)
#   frontend/.env.local   →  optional (see frontend/.env.example)
#
# Quick setup:
#   cp backend/.env.example backend/.env
#   docker compose up -d && pnpm dev
